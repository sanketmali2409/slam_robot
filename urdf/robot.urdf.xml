<?xml version="1.0"?>
<robot name="slam_robot">

  <!-- ==================== MATERIALS ==================== -->
  <material name="blue">
    <color rgba="0.1 0.3 0.8 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="cyan">
    <color rgba="0.0 1.0 1.0 1.0"/>
  </material>

  <!-- ==================== BASE LINK ==================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <!-- A simple chassis that encloses the wheel mounts -->
        <box size="0.10 0.35 0.06"/>
      </geometry>
      <material name="blue"/>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
    </visual>
  </link>

  <!-- ==================== WHEELS ==================== -->
  <!-- Dimensions pulled from your serial_bridge_node parameters:
       wheel_radius: 0.03m
       wheel_base_x: 0.0425m
       wheel_base_y: 0.185m
  -->

  <!-- Front Left Wheel -->
  <link name="wheel_front_left">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="joint_fl" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_front_left"/>
    <!-- Rotate the cylinder so it rolls forward -->
    <origin xyz="0.0425 0.185 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Front Right Wheel -->
  <link name="wheel_front_right">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="joint_fr" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_front_right"/>
    <origin xyz="0.0425 -0.185 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Back Left Wheel -->
  <link name="wheel_back_left">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="joint_bl" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_back_left"/>
    <origin xyz="-0.0425 0.185 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Back Right Wheel -->
  <link name="wheel_back_right">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="joint_br" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_back_right"/>
    <origin xyz="-0.0425 -0.185 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ==================== LASER SENSOR ==================== -->
  <link name="base_laser">
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.04"/>
      </geometry>
      <material name="cyan"/>
    </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_laser"/>
    <origin xyz="0.05 0.0 0.08" rpy="0 0 0"/>
  </joint>

</robot>
