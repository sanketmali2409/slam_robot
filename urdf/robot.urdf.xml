<?xml version="1.0"?>
<robot name="slam_robot">

  <!-- ==================== BASE LINK ==================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.20 0.15 0.08"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.20 0.15 0.08"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0"
               iyy="0.01" iyz="0"
               izz="0.01"/>
    </inertial>
  </link>

  <!-- ==================== LASER LINK ==================== -->
  <link name="base_laser"/>

  <!-- ==================== LASER JOINT ==================== -->
  <!-- IMPORTANT: Measure where your RPLIDAR actually sits on the robot.
       xyz="forward  left  up" from center of base_link.
       Adjust x, z values to match your physical build.         -->
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="base_laser"/>
    <origin xyz="0.05 0.0 0.10" rpy="0 0 0"/>
  </joint>

</robot>
